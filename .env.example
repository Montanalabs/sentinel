# Sentinel configuration (copy to .env; never commit .env)

# Provenance store. Defaults to `memory` so a fresh clone runs with no setup. One of:
#   memory                         in-process, non-durable (dev) — the default below
#   sqlite:./sentinel.db           durable single-node, no server (uses node:sqlite, Node >=22.5)
#   postgres://user:pass@host/db   durable, multi-writer / HA
SENTINEL_DATABASE_URL=memory
# Integration-test DB (only used by *.int.test.ts; point at your own Postgres to run them)
SENTINEL_TEST_DATABASE_URL=postgres://sentinel:sentinel@localhost:5432/sentinel_test

# Cross-model second opinion. Defaults to `mock` (no API key needed, runs offline).
# Switch to `anthropic` or `openai` and supply YOUR OWN key + model to use a real reviewer.
SENTINEL_SECOND_OPINION_PROVIDER=mock        # mock | anthropic | openai
SENTINEL_SECOND_OPINION_MODEL=               # e.g. claude-sonnet-4-6 (anthropic) or gpt-5.5 (openai)
ANTHROPIC_API_KEY=                           # your Anthropic key (only if provider=anthropic)
OPENAI_API_KEY=                              # your OpenAI key (only if provider=openai)

# Sidecar
SENTINEL_SIDECAR_PORT=4000
# Signing key (Ed25519, base64 seed). If unset, an ephemeral key is generated at boot.
SENTINEL_SIGNING_SEED=

# Escalation webhook (optional)
SENTINEL_ESCALATION_WEBHOOK_URL=

# Slow-tier deadline (model/ledger calls), ms. Default 2000 (mock) / 12000 (real provider).
SENTINEL_SLOW_BUDGET_MS=
# Rate limit on /v1/* (both required to enable): burst capacity + refill tokens/sec.
SENTINEL_RATE_LIMIT_BURST=
SENTINEL_RATE_LIMIT_RPS=
# Max concurrent in-flight /v1/* requests (503 when exceeded).
SENTINEL_MAX_CONCURRENT=

# Adjudication protocol (opt-in). When enabled, exposes /v1/adjudications, /v1/receipts/validate,
# /v1/executions, /v1/receipts/revoke, and /v1/audit/* alongside the core gate API.
SENTINEL_PROTOCOL_ENABLED=                    # 1 | true | yes | on to enable (default off)
# Issuer identity stamped into authorization receipts. Default: sentinel-gate.
SENTINEL_PROTOCOL_ISSUER=
# Trusted executor signer public keys for execution ingest + audit, as keyId:base64,keyId2:base64.
# (The gate is not the executor; executors sign their own execution receipts with their own keys.)
SENTINEL_PROTOCOL_EXECUTOR_KEYS=
# NOTE: durable protocol persistence requires a `sqlite:` SENTINEL_DATABASE_URL. With a memory or
# postgres store URL the receipt/execution/nonce log is in-memory only (non-durable).
